{
  "name": "ceveto",
  "description": "Ceveto MCP server — AI agent access to the Ceveto business management API",
  "version": "1.1.0",
  "author": {
    "name": "Ceveto"
  },
  "homepage": "https://github.com/Ceveto/claude-plugin",
  "repository": "https://github.com/Ceveto/claude-plugin",
  "license": "MIT",
  "mcpServers": {
    "ceveto": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/Ceveto/mcp-server", "ceveto-mcp"],
      "env": {
        "CEVETO_MCP_BASE_URL": "https://api.ceveto.com",
        "CEVETO_MCP_HOSTED_MODE": "true"
      }
    }
  }
}
